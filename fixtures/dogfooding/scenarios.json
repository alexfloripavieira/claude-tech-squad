    {
      "id": "rollover-midimplement",
      "workflow": "rollover",
      "repo_path": "fixtures/dogfooding/layered-monolith",
      "prompt": "/claude-tech-squad:rollover\nAssume an /implement run has produced two phase outputs and is about to enter the review phase. Invoke /rollover to consolidate state. Then demonstrate /resume-from-rollover reading the machine state JSON, re-emitting invariants, and handing control back.",
      "expected_architecture_style": [
        "existing-repo-pattern",
        "layered"
      ],
      "expected_agents": [
        "context-summarizer"
