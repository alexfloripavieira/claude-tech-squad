        "hexagonal-architect",
        "backend-architect"
      ],
      "forbidden_default_agents": [],
      "required_trace_lines": [
        "[Preflight Start] discovery",
        "[Preflight Passed] discovery",
        "[Preflight Start] implement",
        "[Preflight Passed] implement",
        "[Checkpoint Saved] implement"
      ],
      "forbidden_strings": [
        "code-debugger"
      ],
      "artifact_contract": [
        "prompt.txt",
        "trace.md",
        "final.md",
        "metadata.yaml",
        "scorecard.md"
      ]
    },
