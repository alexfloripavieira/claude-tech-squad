      "forbidden_default_agents": [],
      "required_trace_lines": [
        "[Rollover Requested]",
        "[Teammate Spawned] context-summarizer",
        "[Rollover Accepted]",
        "[Resume From]",
        "[Resume Accepted]"
      ],
      "forbidden_strings": [
        "[Rollover Error]",
        "[Resume Error]"
      ],
      "artifact_contract": [
        "prompt.txt",
        "trace.md",
        "final.md",
        "metadata.yaml",
        "scorecard.md",
        "rollover-brief.md",
        "rollover-state.json"
      ],
      "rollover_artifact_schema": {
        "required_keys": [
          "schema_version",
          "run_id",
          "skill",
          "completed_phases",
          "open_decisions",
          "invariants",
          "next_action",
          "checkpoint_cursor"
        ],
        "schema_version": "1.0"
      }
