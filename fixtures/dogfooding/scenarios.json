{
  "version": 1,
  "scenarios": [
    {
      "id": "layered-monolith",
      "workflow": "discovery",
      "repo_path": "fixtures/dogfooding/layered-monolith",
      "prompt": "/claude-tech-squad:discovery\nDesign a delivery slice for audit-log filters in an existing layered monolith. Preserve the current repository structure, propose only the specialists that are actually needed, and show explicit preflight and execution lines.",
      "expected_architecture_style": [
        "existing-repo-pattern",
        "layered"
      ],
      "expected_agents": [
        "backend-architect"
      ],
      "forbidden_default_agents": [
        "hexagonal-architect"
      ],
      "required_trace_lines": [
        "[Preflight Start] discovery",
        "[Preflight Passed] discovery",
        "[Checkpoint Saved] discovery",
        "[Team Created] discovery"
      ],
      "forbidden_strings": [
        "code-debugger"
      ],
      "artifact_contract": [
        "prompt.txt",
        "trace.md",
        "final.md",
        "metadata.yaml",
        "scorecard.md"
      ]
    },
    {
      "id": "hexagonal-billing",
